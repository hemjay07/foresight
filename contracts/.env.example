# ============================================================================
# Foresight Smart Contract Deployment Configuration
# ============================================================================

# Base Sepolia RPC URL
# Get free RPC from: https://www.alchemy.com or https://infura.io
# Public RPC: https://sepolia.base.org (rate limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key for deployment (DO NOT USE YOUR MAIN WALLET)
# Create a new burner wallet specifically for deployment
# Format: 64 character hex string (without 0x prefix)
# Example: abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890
PRIVATE_KEY=your_deployer_private_key_here_without_0x

# Etherscan API Key for contract verification
# Get from: https://basescan.org/myapikey
# Required for --verify flag in deployment
ETHERSCAN_API_KEY=your_basescan_api_key_here

# Treasury address (receives failed prediction stakes)
# This should be a secure wallet you control
# Format: 0x... Ethereum address
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
