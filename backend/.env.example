# ============================================
# Foresight Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================

# Port the server will run on
PORT=3001

# Environment (development | production)
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================

# PostgreSQL connection string
# Format: postgresql://[user[:password]@][host][:port][/database]
# Local example (no password): postgresql://localhost:5432/foresight
# Production example: postgresql://user:password@host:5432/foresight?ssl=true
DATABASE_URL=postgresql://localhost:5432/foresight

# ============================================
# Authentication
# ============================================

# JWT secret key for signing tokens
# IMPORTANT: Generate a random string for production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Blockchain Configuration
# ============================================

# Base Network RPC URL
# Sepolia (testnet): https://sepolia.base.org
# Mainnet: https://mainnet.base.org
RPC_URL=https://sepolia.base.org

# Chain ID
# Base Sepolia: 84532
# Base Mainnet: 8453
CHAIN_ID=84532

# ============================================
# Smart Contract Addresses
# ============================================

# CT Draft contract address
CT_DRAFT_ADDRESS=0x378105C2081Cc2235e6637DC9757a63F20263aa9

# Reputation Engine contract address
REPUTATION_ENGINE_ADDRESS=0x24C8171af3e2EbA7fCF53BDB5B958Ed2AB36fb0c

# Treasury contract address
TREASURY_ADDRESS=0x7A395d0B4E1542335DB3478171a08Cf34E97180f

# Timecaster Arena contract address
TIMECASTER_ARENA_ADDRESS=0x5b8e61e873da5EC1616b3931F4Bc7Fc32D1B9F62

# Daily Gauntlet contract address
DAILY_GAUNTLET_ADDRESS=0x16ABD5fC02Ba7E64527320b2C042BaaCBc2BB854

# Foresight NFT contract address
FORESIGHT_NFT_ADDRESS=0x8DCEb1aC97d3Ab305b6d7B2D44305d3F52c26bfa

# Quest Rewards contract address
QUEST_REWARDS_ADDRESS=0xE3a2f682A5F22221F5f67c3cda917D7058aAbfe8

# Prized Contests V2 contract address
PRIZED_V2_CONTRACT_ADDRESS=0xc9296C7D0868C99b9cB5bAbe783f5a23bBa6033a

# Base Sepolia RPC URL (can be same as RPC_URL or use a different provider)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ============================================
# Frontend Configuration
# ============================================

# Frontend URL for CORS configuration
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# Twitter API (TwitterAPI.io)
# ============================================

# TwitterAPI.io API Key
# Get your key from: https://twitterapi.io
# ~$0.70/month for 50 influencers
# IMPORTANT: Keep this secret! Never commit to git.
TWITTER_API_IO_KEY=your-twitter-api-io-key-here
