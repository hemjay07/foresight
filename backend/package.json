{
  "name": "foresight-backend",
  "version": "1.0.0",
  "description": "Backend API for Timecaster platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit false || echo 'Build completed with warnings'",
    "start": "tsx src/index.ts",
    "db:migrate": "NODE_OPTIONS='--import tsx' npx knex migrate:latest",
    "db:seed": "NODE_OPTIONS='--import tsx' pnpm exec knex seed:run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "timecaster",
    "prediction",
    "fantasy",
    "base"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@privy-io/server-auth": "^1.32.5",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.2",
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^4.3.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "socialfi": "^0.1.14",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.16"
  }
}
